        // Number of product Quantity
        function procuct_Quantity() {
            let plus_recentBtn = document.querySelectorAll(".plus_recentBtn");
            let minus_recentBtn = document.querySelectorAll(".minus_recentBtn");
            let itemQuantity = document.querySelectorAll(".itemQuantity");
            let minimum_Value = 1;
            minus_recentBtn.forEach((e, i) => {
                e.addEventListener("click", function (event) {
                    itemQuantity.forEach((input, index) => {
                        if (index == i) {
                            if (input.value <= minimum_Value) {
                                minus_recentBtn[index].disabled = true;
                                return;
                            } else {
                                minus_recentBtn[index].disabled = false;
                            }

                            input.value--;
                            input.setAttribute("value", input.value)
                            input.setAttribute("product_quantity", input.value);
                        }
                    })
                })
            })
            plus_recentBtn.forEach((ele, ind) => {
                ele.addEventListener("click", function (event) {
                    itemQuantity.forEach((input, index) => {
                        if (index == ind) {
                            if (input.value >= minimum_Value) {
                                minus_recentBtn[index].disabled = false;
                            }
                            // let input_value = parseInt(input.value);
                            // let result_num = input_digit + 1;
                            input.value++;
                            
                            input.setAttribute("value", input.value)
                            input.setAttribute("product_quantity", input.value);
                        }
                    })
                })
            })

        }
        procuct_Quantity();

