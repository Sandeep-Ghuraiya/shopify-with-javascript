<script>
  function reactView_blockfn(){
    let grid_container = document.getElementById("ul_reactView_product-grid");
    let mmt_closeModal = document.getElementById("mmt_closeRecentModal");

    // popup modal after 2 min
    // var modalpop = document.getElementById("ksmyModal");
    // var myModal = document.getElementById("myModal");

    // const myTimeout = setTimeout(function () {
    //     showModalPopup()
    // }, 5000);
  
    mmt_closeModal.addEventListener("click", (e) =>{
       document.getElementById("variantRecentModal").style.display = "none";
       window.location.reload(); 
    })

    // function showModalPopup() {

    //     document.getElementById("myModal").style.backgroundColor = "rgba(0,0,0,0.4)";

    //     document.getElementById("modal2").innerHTML = data1
    //     document.getElementById("myModal").style.display = "block";
    //     // procuctQuantity();
    //     // showAddTocard();
    //     modalQuantity();
    //     popUpAddTocard()

    // };

  
    // Product Doller price code
    let usd_price = [];
    let usd_price2 = [];
    let usd_price_v = [];
  
    function get_only_price(string) {
        var varients_price = string.replace(",", "");
        varients_price = varients_price.replace(/[^0-9,.]*/, "");
        varients_price = parseFloat(varients_price);
        US_price_format(varients_price);
    }
  
    function get_only_price2(string) {
        var varients_price = string.replace(",", "");
        varients_price = varients_price.replace(/[^0-9,.]*/, "");
        varients_price = parseFloat(varients_price);
        US_price_formatCopy(varients_price)
    }
  
    function US_price_format(price) {
        var formater = new Intl.NumberFormat("en-US", {
            style: "currency",
            currency: "USD",
        });
        usd_price.push(formater.format(price));
    }
  
    function US_price_formatCopy(price) {
        var formater = new Intl.NumberFormat("en-US", {
            style: "currency",
            currency: "USD",
        });
        usd_price2.push(formater.format(price));
    }

    // Varient Doller Price
    function US_price_format_v(Vprice) {
        let varients_price = parseFloat(Vprice);
        var formater = new Intl.NumberFormat("en-US", {
            style: "currency",
            currency: "USD",
        });
        usd_price_v.push(formater.format(varients_price));
    }
  
    let url = 'http:{{ 'product_data.json' | asset_url }}';

    fetch(url)
    .then(res => res.json())
    .then((data) => {
      let product_data = data;
      product_gridFn(product_data)
    })
    .catch(err => { throw err });   
   
  // timeDiv.innerHTML = '';
    function product_gridFn(product_data){
      setTimeout(function(){
        
        let mmt_product_Data = product_data.products;
        console.log("Product data: ", mmt_product_Data)
        
        let data1 = "";
        let modal;
        
        mmt_product_Data.forEach((ele, i) => { 
          get_only_price(ele.variants[0].price);
      
         if(i < 4) {
          data1 += `<li class="mmt_grid__item">
                <div class="mmt_card-wrapper">
                  <div class="mmt_contenWithimage">
                    <a href="#" class="mmt_card mmt_card--product" alt="product_link">
                        <div class="mmt_card__inner">
                            <div class="mmt_product_image_section">
                                <div class="mmt_card_media mmt-transparent media--square mmt--hover-effect">
                                    <img src="//cdn.shopify.com/s/files/1/0471/0698/2044/products/7-chakra-bracelet_925x_56334c2a-fe85-4a78-ae6f-bb8494b258ff_533x.jpg?v=1614964099"
                                        alt="7 Shakra Bracelets IIIIP" loading="lazy" class="mmt_card__image mmt_img1">
                                    <img src="${ele.images[0].src}"
                                        alt="7 Shakra Bracelets IIIIP" loading="lazy" class="mmt_card__image mmt_img2">
                                </div>
                            </div>
                            ${ele.variants[0].inventory_quantity > 0 ? `<div class="mmt_card__badge">
                              <span class="badge badge--bottom-left color-accent-2">Sale</span>
                            </div>`: `<span class="hidden"></span>` }   
                        </div>
                    </a>
                    <div class="mmt_card-information">
                        <div class="mmt_card-information__wrapper">
                            <h3 class="mmt_card-information__text mmt_h5">
                                <a href="#" class="mmt_full-link mmt_fullTitle_link a_link" id="${i}" data-titlename="${ele.title}">
                                    ${ele.title}
                                </a>
                            </h3>
                            <div class="mmt_price  mmt_price-sale ">
                                <div>
                                    <div class="mmt_price__regular">
                                        <span class="mmt_visually-hidden mmt_visually-hidden--inline">Regular price</span>
                                        <span 
                                          class="mmt_price-item mmt_price-item--regular product_price" 
                                          data-price="${ele.variants[0].price}" data-indexNumber="${i}"> 
                                          ${usd_price[i]}
                                        </span>
