.banner--small:not(.banner--adapt) {
    min-height: 42rem;
}

.banner--medium:not(.banner--adapt) {
    min-height: 56rem;
}

.banner--large:not(.banner--adapt) {
    min-height: 72rem;
}

banner--{{ section.settings.slide_height }}



<div class="slide-inner slide-bg-image">
                        {%- if block.settings.image_pics != blank -%}  
                        <div class="slide-image_container">
                           <div class="slide-image--wrapper">
                               <img src="{{ block.settings.image_pics | img_url: 'master' }}"  class="slider__img"/> 
                           </div>
                        </div>
                        {% endif %}
                        
                        <div class="text_container">
                            <div class="slider-text_wrapper">
                              {%- if block.settings.banner_subheading != blank -%}   
                              <div class="slide-text">
                                  <p>{{ block.settings.banner_subheading }}</p>
                              </div>
                              {% endif %}
                              {%- if block.settings.banner_heading != blank -%}  
                              <div class="slide-title">
                                  <h2>{{ block.settings.banner_heading }}</h2>
                              </div>
                              {% endif %}
                                
                              {%- if block.settings.btn_label != blank -%}   
                              <div class="slide-btns">
                                  <a href="{% if block.settings.btn_link != blank %}{{ block.settings.btn_link }}{% else %}#{% endif %}" class="theme-btn-s2">
                                    <span>{{ block.settings.btn_label }}</span>
                                  </a>
                              </div>
                              {% endif %}  
                            </div>
                        </div>
                    </div>